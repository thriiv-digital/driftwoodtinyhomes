      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|primary|teal|accent|success|warning|error|info|brand|brand-teal)$/]",
        "message": "<Badge> variant must be one of 'default' | 'primary' | 'teal' | 'accent' | 'success' | 'warning' | 'error' | 'info' | 'brand' | 'brand-teal'."
